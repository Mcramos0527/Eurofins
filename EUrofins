/* ================= STATE / STORAGE ================= */
let current = 0;
let stateCache = {};

async function loadState(){
  for(const s of STAGES){
    try{
      const r = await window.storage.get('stage:'+s.id, false);
      stateCache[s.id] = r ? JSON.parse(r.value) : {answer:"", done:false, revealed:false};
    }catch(e){
      stateCache[s.id] = {answer:"", done:false, revealed:false};
    }
  }
}
async function saveState(id){
  try{ await window.storage.set('stage:'+id, JSON.stringify(stateCache[id]), false); }catch(e){}
}

/* ================= RENDER ================= */
function renderSidebar(){
  const list = document.getElementById('stageList');
  list.innerHTML = "";
  let lastCat = null;
  STAGES.forEach((s, i)=>{
    if(s.cat !== lastCat){
      const head = document.createElement('div');
      head.className = 'cat-head';
      head.textContent = s.cat;
      list.appendChild(head);
      lastCat = s.cat;
    }
    const btn = document.createElement('button');
    btn.className = 'stage-btn' + (i===current ? ' active':'');
    const done = stateCache[s.id] && stateCache[s.id].done;
    btn.innerHTML = '<span class="stage-num">'+String(i+1).padStart(2,'0')+'</span><span class="stage-label">'+s.label+'</span><span class="stage-check '+(done?'done':'')+'">&#10003;</span>';
    btn.onclick = ()=>{ current = i; renderAll(); };
    list.appendChild(btn);
  });
  const doneCount = STAGES.filter(s=>stateCache[s.id] && stateCache[s.id].done).length;
  document.getElementById('progressFill').style.width = (doneCount/STAGES.length*100)+'%';
  document.getElementById('progressText').textContent = doneCount + ' / ' + STAGES.length + ' stages complete';
}

function renderMain(){
  const s = STAGES[current];
  const st = stateCache[s.id];
  const main = document.getElementById('main');
  main.innerHTML =
    '<div class="cat-pill">'+s.cat+'</div>'+
    '<div class="label-card"><span class="tab-notch">'+String(current+1).padStart(2,'0')+'</span>'+s.tag+'</div>'+
    '<h2 class="stage-title">'+s.title+'</h2>'+
    '<p class="stage-sub">'+s.sub+'</p>'+
    (st.done ? '<div class="status-stamp">&#10003; STAGE SIGNED OFF</div>' : '') +
    '<div class="mentor"><div class="who">Your Trainer</div>'+ s.mentor.map(p=>'<p>'+p+'</p>').join('') +'</div>'+
    '<div class="panel-card"><h3>Your Task</h3>'+
    '<div class="note-block">'+s.task+'</div>'+
    '<textarea id="answerBox" placeholder="'+s.placeholder.replace(/"/g,'&quot;')+'">'+(st.answer||'')+'</textarea>'+
    '<div class="btn-row">'+
    '<button class="act primary" id="revealBtn">Reveal Trainer&rsquo;s Model Answer</button>'+
    '<button class="act done-btn" id="doneBtn">'+(st.done ? 'Marked Complete' : 'Mark Stage Complete')+'</button>'+
    '</div>'+
    '<div class="reveal '+(st.revealed?'show':'')+'" id="revealBlock">'+
    '<div class="who">What A Strong Answer Looks Like</div>'+
    '<div class="reveal-body">'+s.reveal+'</div></div>'+
    '</div>'+
    '<div class="nav-foot">'+
    '<button class="act" id="prevBtn" '+(current===0?'disabled style="opacity:.35"':'')+'>Previous Stage</button>'+
    '<button class="act" id="nextBtn" '+(current===STAGES.length-1?'disabled style="opacity:.35"':'')+'>Next Stage</button>'+
    '</div>';

  const box = document.getElementById('answerBox');
  box.addEventListener('input', ()=>{
    st.answer = box.value;
    saveState(s.id);
  });
  document.getElementById('revealBtn').onclick = ()=>{
    st.revealed = true;
    document.getElementById('revealBlock').classList.add('show');
    saveState(s.id);
  };
  document.getElementById('doneBtn').onclick = ()=>{
    st.done = !st.done;
    saveState(s.id);
    renderAll();
  };
  document.getElementById('prevBtn').onclick = ()=>{ if(current>0){ current--; renderAll(); } };
  document.getElementById('nextBtn').onclick = ()=>{ if(current<STAGES.length-1){ current++; renderAll(); } };
}

function renderAll(){ renderSidebar(); renderMain(); }

document.getElementById('resetBtn').onclick = async ()=>{
  if(!confirm("Reset all progress and saved answers? This can't be undone.")) return;
  for(const s of STAGES){
    stateCache[s.id] = {answer:"", done:false, revealed:false};
    await saveState(s.id);
  }
  current = 0;
  renderAll();
};

(async function init(){
  await loadState();
  renderAll();
})();
</script>
